# Токен бота от @BotFather
BOT_TOKEN=123456:ABCDEF...

# Ключ Google Gemini API (бесплатный)
# Получить: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSy...

# Модель Gemini (по умолчанию gemini-2.5-flash — бесплатный тариф)
# Альтернативы: gemini-2.5-flash-lite (быстрее, дешевле), gemini-2.0-flash
GEMINI_MODEL=gemini-2.5-flash

# Provider token для Telegram Payments (получить у @BotFather → /mybots → Payments)
# Для тестов используйте тестовый токен (ЮKassa Test, Stripe Test и т.п.)
PAYMENT_PROVIDER_TOKEN=381764678:TEST:...

# Цена подписки в минимальных единицах валюты (49900 = 499.00 RUB)
SUBSCRIPTION_PRICE=49900
SUBSCRIPTION_CURRENCY=RUB
SUBSCRIPTION_DAYS=30

# Длительность бесплатного пробного периода (дней)
TRIAL_DAYS=2

# Через сколько часов после еды с БЖЕ напоминать
BJE_REMINDER_HOURS=2

# Минимальное количество БЖЕ для напоминания
BJE_REMINDER_THRESHOLD=1.0
